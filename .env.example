# Copy to .env at project root and adjust values

### Database
USE_INFDB = True
DBNAME = "infdb"
DBUSER = "infdb_user"
HOST = "localhost"
PORT = "54321"
PASSWORD = "your_infdb_password"
INFDB_SOURCE_SCHEMA="basedata"

### Path Configuration (Optional - for advanced setups with Docker)
# PYLOVO_ROOT="/app"  # Project root directory
# PYLOVO_DATA_DIR="/path/to/data"  # Override data directory location (defaults to ./data)
# PYLOVO_CONFIG_DIR="/path/to/config"  # Override config directory location (defaults to ./config)

### Validation (for developers)
# GRID_DATA_PATH="/path/to/your/validation/grid_data/"
# NET_NAME="name_of_your_network"

